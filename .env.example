# Copy this file to backend/.env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Postgres (default for development):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/miromarket

# Supabase (replace with your project credentials):
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── LLM Models (LiteLLM format: "provider/model-name") ───────────────────────
# These can be swapped freely — see https://docs.litellm.ai/docs/providers
AGENT_MODEL=openai/gpt-4o-mini
REPORT_MODEL=openai/gpt-4o

# ── LLM API Keys (only add keys for providers you use) ───────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── Kalshi ────────────────────────────────────────────────────────────────────
KALSHI_API_KEY=
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
